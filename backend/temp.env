# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=plutovets
DB_USER=postgres
DB_PASSWORD=1234

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here_123456
JWT_REFRESH_SECRET=your_super_secret_refresh_key_here_123456
JWT_EXPIRE=24h
JWT_REFRESH_EXPIRE=7d

# Firebase Configuration
FIREBASE_PROJECT_ID=plutovets-demo
FIREBASE_PRIVATE_KEY_ID=demo_key
FIREBASE_PRIVATE_KEY=\
-----BEGIN
PRIVATE
KEY-----\nDemo_Private_Key\n-----END
PRIVATE
KEY-----\n\
FIREBASE_CLIENT_EMAIL=demo@plutovets.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=demo_client_id
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME=demo_cloud
CLOUDINARY_API_KEY=demo_api_key
CLOUDINARY_API_SECRET=demo_api_secret

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=demo@gmail.com
EMAIL_PASS=demo_password

# External APIs
ANIMAL_DATA_API_KEY=demo_api_key
VET_CLOUD_API_KEY=demo_api_key
